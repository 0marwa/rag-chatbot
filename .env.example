# copy this to .env and fill in your groq key
# cp .env.example .env

# which providers to use
LLM_PROVIDER=groq
EMBEDDING_PROVIDER=local

# groq (default, free tier) -> https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# local embeddings (no key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# retrieval
TOP_K=4
SIMILARITY_THRESHOLD=0.3

# where the vector store lives on disk
DB_PATH=chroma_db

# copy this to .env and fill in whatever provider you're using
# you only need the key for the llm provider you actually pick

# groq (default, free tier) -> https://console.groq.com
GROQ_API_KEY=

# openai (optional)
OPENAI_API_KEY=

# gemini (optional)
GOOGLE_API_KEY=

# mistral (optional)
MISTRAL_API_KEY=

# which provider to use
LLM_PROVIDER=groq
EMBEDDING_PROVIDER=local
